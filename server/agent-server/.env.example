# Nexus AI Agent Server - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ===========================================
# NVIDIA API (Obrigatório)
# ===========================================
# Obtenha sua chave em: https://developer.nvidia.com/nim
NVIDIA_API_KEY=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

# Modelo NVIDIA (padrão: llama-3.3-nemotron-70b-instruct)
# Outros modelos disponíveis:
# - meta/llama-3.1-405b-instruct
# - google/gemma-2-27b-it
# - mistralai/mixtral-8x7b-instruct-v0.1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-70b-instruct

# ===========================================
# CONFIGURAÇÕES DE GERAÇÃO
# ===========================================
# Tokens máximos por resposta
MAX_TOKENS=2048

# Temperatura (0.0 a 1.0) - 0.7 é bom para equilíbrio
TEMPERATURE=0.7

# ===========================================
# SERVIDOR
# ===========================================
# Porta do servidor (padrão: 8000)
PORT=8000

# Host (0.0.0.0 para aceitar conexões externas)
HOST=0.0.0.0

# ===========================================
# CORS (Produção)
# ===========================================
# Domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=https://nexusholding.com,https://www.nexusholding.com